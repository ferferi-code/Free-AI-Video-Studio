# ==========================================
# LLM Provider Selection
# ==========================================
# Options: auto, openrouter, openai, groq, gemini, local
# "auto" = Smart fallback: tries openrouter -> gemini -> groq -> openai -> local (offline)
LLM_PROVIDER=auto

# ==========================================
# LLM Model Configurations
# ==========================================
OPENROUTER_MODEL=openai/gpt-4o
OPENAI_MODEL=gpt-4o
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-1.5-flash

# ==========================================
# API Keys
# ==========================================
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ==========================================
# Video Source API Keys
# ==========================================
PEXELS_API_KEY=your_pexels_api_key_here
MUAPI_API_KEY=your_muapi_api_key_here

# ==========================================
# Muapi Configuration (Optional - for Premium AI Video/Music)
# ==========================================
MUAPI_BASE_URL=https://api.muapi.ai
MUAPI_VIDEO_MODEL=veo3-fast-text-to-video

# ==========================================
# Video Orientation
# ==========================================
# Options: portrait (vertical, 1080x1920) or landscape (horizontal, 1920x1080)
VIDEO_ORIENTATION=portrait

# ==========================================
# Speech-to-Text Provider (For Timed Captions)
# ==========================================
# Options: whisper (Free, local) or deepgram (Paid, cloud-based)
STT_PROVIDER=whisper
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ==========================================
# Text-to-Speech Provider (Voiceover)
# ==========================================
# Options: edgetts (Free, Online), elevenlabs (Paid, Premium), local (Free, Offline, Emotion-Aware via Bark)
TTS_PROVIDER=local

# EdgeTTS Voice Configuration (Required if TTS_PROVIDER=edgetts)
EDGETTS_VOICE=en-US-GuyNeural

# ElevenLabs Configuration (Required if TTS_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Local TTS Configuration (Required if TTS_PROVIDER=local)
# Uses Suno Bark. Downloads ~2GB on first run, then works 100% offline with emotion tags.
# Options: v2/en_speaker_0 to v2/en_speaker_9 (v2/en_speaker_6 is highly recommended)
LOCAL_TTS_VOICE=v2/en_speaker_6

# ==========================================
# Background Music Configuration
# ==========================================
# If MUAPI_API_KEY is missing, the system will automatically fallback to local MusicGen.
# Set to false to disable background music entirely.
LOCAL_MUSIC_ENABLED=true

# ==========================================
# Audio Ducking Configuration (2026 Standard)
# ==========================================
# Automatically lowers background music volume when the voiceover is speaking.
AUDIO_DUCKING_ENABLED=true

# ==========================================
# Caption Configuration
# ==========================================
CAPTIONS_ENABLED=true

# Caption Style Options: hormozi, card, neon, minimal, karaoke, comic
# - hormozi: Bold, yellow/white, thick black outline (Highest engagement)
# - card: White text on semi-transparent black background (Best readability)
# - neon: Glowing cyan/magenta text with white outline (Gen-Z aesthetic)
# - minimal: Clean white text, thin black outline (Professional)
# - karaoke: Highlights current word in yellow/green (High retention)
# - comic: Playful font with thick outline (Entertainment)
CAPTION_STYLE=hormozi

CAPTION_FONT_SIZE=100
CAPTION_FONT_COLOR=yellow
CAPTION_FONT_FACE=Arial-Bold
CAPTION_STROKE_WIDTH=4
CAPTION_STROKE_COLOR=black
CAPTION_POSITION=bottom_center

# ==========================================
# Moving Watermark Configuration (Optional)
# ==========================================
# Adds a semi-transparent, gently floating watermark to prevent unauthorized copying.
WATERMARK_ENABLED=true

# The text to display (e.g., your channel handle, website, or ID)
WATERMARK_TEXT=@YourChannelID

# Watermark text color (white, black, yellow, cyan, red, green, blue)
WATERMARK_COLOR=white

# Watermark opacity (0.1 to 0.9). Lower = more transparent.
WATERMARK_OPACITY=0.3

# ==========================================
# Render Engine Configurations
# ==========================================
# Options: moviepy (legacy/fast, Python-based) or remotion (React-based, advanced)
RENDER_ENGINE=moviepy

# Remotion Theme (only applies if RENDER_ENGINE=remotion)
# Options: clean-professional, flat-motion-graphics, minimalist-diagram, anime-ghibli
REMOTION_THEME=flat-motion-graphics
